# Local Development Secrets for k3s
# ⚠️ DO NOT COMMIT THIS FILE TO GIT - USE local-secrets.yaml.example INSTEAD
# Copy this file to local-secrets.yaml and update with your actual values

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: podland
type: Opaque
stringData:
  password: "dev-password-change-me-12345"
---
apiVersion: v1
kind: Secret
metadata:
  name: podland-backend-secret
  namespace: podland
type: Opaque
stringData:
  jwt-secret: "dev-jwt-secret-min-32-random-characters-here"
  refresh-token-secret: "dev-refresh-token-secret-min-32-chars"
  github-client-id: "Iv1.0000000000000000"
  github-client-secret: "0000000000000000000000000000000000000000"
