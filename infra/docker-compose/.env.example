# PostgreSQL Configuration
POSTGRES_DB=podland
POSTGRES_USER=podland
POSTGRES_PASSWORD=podland_password_change_me

# Backend Configuration
ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback
DATABASE_URL=postgresql://podland:podland_password_change_me@postgres:5432/podland?sslmode=disable
JWT_SECRET=change-me-jwt-secret-min-32-random-characters-here
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32-chars
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:8080
