{
  "name": "podland",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@podland/frontend",
    "dev:backend": "cd apps/backend && go run ./cmd/main.go",
    "build:frontend": "npm run build --workspace=@podland/frontend",
    "build:backend": "cd apps/backend && go build -o bin/backend ./cmd/main.go",
    "test:backend": "cd apps/backend && go test ./...",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "clean": "npm run clean --workspaces"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/pluginutils": "^5.3.0",
    "console-control-strings": "^1.1.0",
    "tapable": "^2.3.2",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "@tanstack/router-generator": "^1.120.0",
    "@tanstack/router-plugin": "^1.120.0",
    "@tanstack/react-start-plugin": "^1.120.0",
    "@tanstack/start-plugin-core": "^1.120.0"
  }
}
